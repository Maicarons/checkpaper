# CheckPaper 环境变量配置

# OpenAI API 配置
OPENAI_API_KEY=  # 本地模型无需key
OPENAI_BASE_URL=http://192.168.56.1:8990
OPENAI_MODEL=qwythos-9b-claude-mythos-5-1m
OPENAI_MAX_TOKENS=4096

# 数据库配置
# 本地开发使用 SQLite
DATABASE_URL=sqlite:///./checkpaper.db
# 生产环境使用 MySQL (取消注释并配置)
# DATABASE_URL=mysql+pymysql://checkpaper:your_password@localhost:3306/checkpaper
DB_ECHO=false

# GROBID 服务配置
GROBID_SERVER_URL=http://localhost:8070
GROBID_TIMEOUT=30

# 文件上传配置
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,docx,doc,tex,latex,bib

# API 配置
API_V1_PREFIX=/api/v1
PROJECT_NAME=CheckPaper
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# CORS 配置
BACKEND_CORS_ORIGINS=["http://localhost:9032","http://localhost:9031"]

# 参考文献验证 API 配置
CROSSREF_API_KEY=your_crossref_api_key_here
CROSSREF_MAILTO=your_email@example.com
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# 报告生成配置
REPORT_OUTPUT_DIR=./reports
REPORT_TEMPLATE_DIR=./templates

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/checkpaper.log

# Agent 配置
AGENT_MAX_TURNS=15
AGENT_SANDBOX_ENABLED=true
AGENT_CODE_EXECUTION_TIMEOUT=60

# MCP Server 配置
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001
